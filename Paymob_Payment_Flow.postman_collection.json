              "raw": "{\n  \"type\": \"TRANSACTION\",\n  \"obj\": {\n    \"id\": 192036466,\n    \"pending\": false,\n    \"amount_cents\": 100000,\n    \"success\": false,\n    \"is_auth\": false,\n    \"is_capture\": false,\n    \"is_standalone_payment\": true,\n    \"is_voided\": false,\n    \"is_refunded\": false,\n    \"is_3d_secure\": false,\n    \"integration_id\": 4097558,\n    \"order\": {\n      \"id\": \"{{intention_id}}\",\n      \"amount_cents\": 100000,\n      \"currency\": \"EGP\"\n    },\n    \"created_at\": \"2024-01-15T10:30:00Z\",\n    \"currency\": \"EGP\"\n  }\n}",
